-- СКАНЕР ВСЕХ БОМБ НА КАРТЕ
M:NewButton("ESP: ПОДСВЕТИТЬ ВСЕ БОМБЫ", "Видеть всё у всех", function()
    -- Чистим старые хайлайты
    for _, old in pairs(game.CoreGui:GetChildren()) do
        if old.Name == "BratyxaESP" then old:Destroy() end
    end

    for _, v in pairs(workspace:GetDescendants()) do
        -- Ищем по ключевым признакам: имя "Bomb", черный цвет или меш бомбы
        if v:IsA("BasePart") and (v.Name:lower():find("bomb") or v.Color == Color3.new(0,0,0) or v:FindFirstChild("Mesh")) then
            -- Проверяем, что это не пол или стена (фильтр по размеру)
            if v.Size.X < 5 and v.Size.Z < 5 then
                local h = Instance.new("Highlight")
                h.Name = "BratyxaESP"
                h.Parent = v.Parent -- Подсвечиваем весь чипс, где бомба
                h.FillColor = Color3.fromRGB(255, 0, 0)
                h.FillTransparency = 0.5
                h.OutlineColor = Color3.fromRGB(255, 255, 255)
            end
        end
    end
end)

-- АВТО-СБОР (ПРОБУЕМ НА ВСЕХ СТОЛАХ)
M:NewToggle("AUTO-CLICK ALL TABLES", "Ест всё подряд", function(state)
    _G.Farm = state
    while _G.Farm do
        task.wait(0.05)
        pcall(function()
            for _, v in pairs(workspace:GetDescendants()) do
                if v:IsA("ClickDetector") or v:IsA("TouchTransmitter") then
                    if v.Parent.Name:lower():find("chip") or v.Parent.Name:lower():find("чип") then
                        -- Дистанционный клик
                        fireclickdetector(v)
                    end
                end
            end
        end)
    end
end)

