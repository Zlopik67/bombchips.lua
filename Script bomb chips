local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/xHeptc/Kavo-UI-Library/main/source.lua"))()
local Window = Library.CreateLib("BOMBA CHIPS BY BRATYXANONE90BB", "BloodTheme")

local Main = Window:NewTab("Main")
local Section = Main:NewSection("Ультра Зрение")

-- СКОРОСТЬ (сделал еще быстрее)
Section:NewSlider("MEGA SPEED", "Летай по столам", 1000, 16, function(s)
    game.Players.LocalPlayer.Character.Humanoid.WalkSpeed = s
end)

-- ЖЕСТКИЙ ESP (ВИДИТ ВСЁ)
Section:NewButton("ESP: ВКЛЮЧИТЬ РЕНТГЕН", "Подсветит всё внутри чипсов", function()
    -- Сканируем всё дерево объектов
    for _, v in pairs(workspace:GetDescendants()) do
        -- Если объект внутри чипса или имеет подозрительное имя
        if v:IsA("BasePart") and not v.Parent:IsA("Accessory") and not v.Parent:IsA("Model") == game.Players.LocalPlayer.Name then
            if v.Name:lower():find("bomb") or v.Name:lower():find("бомб") or v.Name == "Handle" then
                -- Создаем подсветку, которую видно сквозь стены
                local Highlight = Instance.new("Highlight")
                Highlight.Parent = v.Parent
                Highlight.FillColor = Color3.fromRGB(255, 0, 0) -- Красный для бомбы
                Highlight.FillTransparency = 0.2
                Highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
                Highlight.AlwaysOnTop = true
            end
        end
    end
end)

-- АВТО-КЛИК (УПРОЩЕННЫЙ)
Section:NewToggle("AUTO-CLICK", "Нажимает на всё рядом", function(state)
    _G.Auto = state
    while _G.Auto do
        task.wait(0.1)
        for _, d in pairs(workspace:GetDescendants()) do
            if d:IsA("ClickDetector") then
                fireclickdetector(d)
            end
        end
    end
end)

local Settings = Window:NewTab("Settings")
Settings:NewSection("Keys"):NewKeybind("Menu (INSERT)", "Скрыть/Показать", Enum.KeyCode.Insert, function()
    Library:ToggleUI()
end)

