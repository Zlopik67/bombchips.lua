-- УЛУЧШЕННЫЙ ПОИСК БОМБЫ
Section:NewButton("ESP: НАЙТИ БОМБУ (V2)", "Ищет скрытые объекты", function()
    for _, v in pairs(workspace:GetDescendants()) do
        -- Проверка на название или на черный цвет (часто бомбы черные)
        if v:IsA("BasePart") and (v.Name:lower():find("bomb") or v.Name:lower():find("бомб") or v.Color == Color3.new(0,0,0)) then
            local h = Instance.new("Highlight")
            h.Parent = v.Parent
            h.FillColor = Color3.fromRGB(255, 0, 0)
            h.OutlineColor = Color3.fromRGB(255, 255, 255)
        end
    end
end)

-- АВТО-КЛИК ПО ЧИПСАМ
Section:NewToggle("AUTO-CLICK CHIPS", "Сам ест чипсы", function(state)
    _G.AutoClick = state
    while _G.AutoClick do
        task.wait(0.1)
        for _, chip in pairs(workspace:GetDescendants()) do
            if chip:IsA("ClickDetector") or chip:IsA("TouchTransmitter") then
                -- Если это чипс (проверка по родителю)
                if chip.Parent.Name:lower():find("chip") or chip.Parent.Name:lower():find("чип") then
                    fireclickdetector(chip)
                    -- Если это тач-зона, просто телепортируемся на секунду
                    firetouchinterest(game.Players.LocalPlayer.Character.HumanoidRootPart, chip.Parent, 0)
                    firetouchinterest(game.Players.LocalPlayer.Character.HumanoidRootPart, chip.Parent, 1)
                end
            end
        end
    end
end)

